{
  "provider": "node",
  "packages": {
    "node": "24"
  },
  "steps": {
    "install": {
      "commands": [
        {
          "src": "packages/paperlesspaper-web/.npmrc.nixpacks",
          "dest": ".npmrc.nixpacks"
        },
        "cp .npmrc.nixpacks \"$HOME/.npmrc\" && NPM_CONFIG_USERCONFIG=\"$HOME/.npmrc\" yarn install --frozen-lockfile && rm -f \"$HOME/.npmrc\" .npmrc.nixpacks"
      ]
    },
    "build": {
      "commands": ["yarn --cwd packages/paperlesspaper-web build:production"]
    }
  }
}
