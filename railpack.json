{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "24"
  },
  "steps": {
    "install": {
      "commands": [
        "cp packages/paperlesspaper-web/.npmrc.nixpacks \"$HOME/.npmrc\" && NPM_CONFIG_USERCONFIG=\"$HOME/.npmrc\" yarn install --frozen-lockfile && rm -f \"$HOME/.npmrc\""
      ]
    },
    "build": {
      "commands": [
        "yarn --cwd packages/paperlesspaper-web build:production"
      ]
    }
  }
}