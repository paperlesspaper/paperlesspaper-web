default_platform(:android)

platform :android do
  def signing_properties
    keystore_path = ENV["ANDROID_KEYSTORE_PATH"].to_s.strip
    keystore_path = File.expand_path("../paperlesspaper-keystore.jks", __dir__) if keystore_path.empty?

    unless File.exist?(keystore_path)
      UI.user_error!("Keystore file not found at '#{keystore_path}'. Set ANDROID_KEYSTORE_PATH or ensure android/paperlesspaper-keystore.jks exists.")
    end

    {
      "android.injected.signing.store.file" => keystore_path,
      "android.injected.signing.store.password" => ENV["FASTLANE_KEY"],
      "android.injected.signing.key.alias" => "key0",
      "android.injected.signing.key.password" => ENV["FASTLANE_KEY"],
    }
  end

  def safe_track_version_codes(track)
    google_play_track_version_codes(track: track)
  rescue => e
    UI.message("Could not fetch version codes for track '#{track}': #{e.message}")
    []
  end

  def max_used_version_code(tracks)
    tracks
      .flat_map { |track| safe_track_version_codes(track) }
      .compact
      .map(&:to_i)
      .max || 0
  end

  def deploy_track(track:, release_status: nil)
    package = load_json(json_path: "../package.json")

    # Must not collide with already-used version codes from other tracks.
    tracks = %w[internal production beta alpha]
    version_code = max_used_version_code(tracks)
    next_version_code = version_code + 1
    puts("Existing version codes max across #{tracks.join(', ')}: #{version_code}")

    increment_version_code(
      version_code: next_version_code,
      gradle_file_path: "./app/build.gradle",
    )

    increment_version_name(
      gradle_file_path: "./app/build.gradle",
      version_name: package["version"],
    )

    gradle(
      task: "app:bundleRelease",
      properties: signing_properties.merge({
        "android.injected.version.name" => package["version"],
        "versionCode" => next_version_code,
        "versionName" => package["version"],
        "applicationId" => ENV["REACT_APP_IDENTIFIER"],
      })
    )

    upload_to_play_store(
      track: track,
      release_status: release_status,
      aab: "app/build/outputs/bundle/release/app-release.aab",
      skip_upload_apk: true,
      version_code: next_version_code,
    )
  end

  desc "Runs all the tests"
  lane :test do
    gradle(task: "test")
  end

  desc "Submit a new Beta Build to Crashlytics Beta"
  lane :beta do
    gradle(task: "clean assembleRelease")
    crashlytics
  
    # sh "your_script.sh"
    # You can also use other beta testing services here
  end


  desc "Deploy a new internal version to the Google Play"
  lane :internal do
    deploy_track(track: "internal")
  end

  desc "Deploy a new production version to the Google Play (automatic release)"
  lane :production do
    deploy_track(track: "production", release_status: "completed")
  end

  desc "Deploy a new version to the Google Play"
  lane :deploy do
    gradle(task: "clean assembleRelease")
    upload_to_play_store
  end
end
