{
  "provider": "node",
  "packages": {
    "node": "24"
  },
  "steps": {
    "install": {
      "commands": [
        {
          "src": ".npmrc.nixpacks",
          "dest": ".npmrc.nixpacks"
        },
        "cp .npmrc.nixpacks .railpack.npmrc && NPM_CONFIG_USERCONFIG=.railpack.npmrc yarn install && rm -f .railpack.npmrc .npmrc.nixpacks"
      ]
    },
    "build": {
      "commands": [
        {
          "path": "/app/node_modules/.bin"
        },
        "yarn build:production"
      ]
    }
  }
}
