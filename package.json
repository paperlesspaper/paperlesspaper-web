{
  "name": "@paperlesspaper/app",
  "version": "0.8.1",
  "private": true,
  "devDependencies": {
    "lerna": "^9.0.4"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "ci:check-no-yalc": "node scripts/check-no-yalc-deps.mjs",
    "hooks:install": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit .githooks/post-commit",
    "mirror:fortawesome": "node scripts/mirror-fortawesome.mjs",
    "mirror:fortawesome:local": "node scripts/mirror-fortawesome.mjs --from-node-modules --node-modules-dir node_modules/@fortawesome",
    "dev:web": "cd packages/web && npm run start:local",
    "dev:api": "cd packages/memo-api && npm run dev",
    "dev:web-local": "cd packages/web && yarn run start:local-https",
    "dev:api-local": "cd packages/memo-api && yarn run dev",
    "build": "lerna run build --stream --prefix",
    "lerna:publish": "lerna publish --conventional-commits",
    "lerna:publishFromPackage": "lerna publish from-package --yes",
    "lerna:version": "lerna version --conventional-commits",
    "lerna:versionNoPush": "lerna version --no-push --conventional-commits --yes",
    "publish:recover": "lerna exec -- \"npm publish  || exit 0\"",
    "bootstrap:api": "lerna bootstrap --include-dependents --include-dependencies --scope=test1",
    "generate:commit": "aicommits --type conventional --generate 5",
    "test": "node helpers/tests/test.js",
    "dev:admin": "yarn --cwd packages/admin dev",
    "build:admin": "yarn --cwd packages/admin build"
  }
}
